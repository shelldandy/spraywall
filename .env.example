# Postgres
POSTGRES_USER=spraywall
POSTGRES_PASSWORD=spraywall
POSTGRES_DB=spraywall
DATABASE_URL=postgres://spraywall:spraywall@postgres:5432/spraywall?sslmode=disable

# MinIO
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_ENDPOINT=minio:9000
MINIO_PUBLIC_ENDPOINT=localhost:9000
MINIO_BUCKET=spraywall

# Server
PORT=8080
JWT_SECRET=dev-jwt-secret-change-me

# Worker
POLL_INTERVAL_SECONDS=5
